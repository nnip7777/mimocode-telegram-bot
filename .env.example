# ─── Required ───────────────────────────────────────────
# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_token_here

# Comma-separated Telegram user IDs allowed to use the bot
# Get yours from @userinfobot
# The bot REFUSES to start if this is empty.
TELEGRAM_ALLOWED_USER_ID=123456789

# ─── Optional ───────────────────────────────────────────
# Working directory for MiMoCode agent (default: current dir)
# MIMO_WORK_DIR=/root

# Attach to an existing MiMoCode server
# MIMO_API_URL=http://127.0.0.1:4096

# Auto-approve ALL agent actions without confirmation.
# DANGER: anyone on the whitelist can make the agent run arbitrary
# commands and read/write files unattended. Leave false unless this
# host is fully disposable/trusted.
MIMO_SKIP_PERMISSIONS=false

# Maximum time (ms) for a single mimo run (default: 120000 = 2 minutes)
# MIMO_RUN_TIMEOUT_MS=300000
