# ─── Required ───────────────────────────────────────────
# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_token_here

# Comma-separated Telegram user IDs allowed to use the bot
# Get yours from @userinfobot
TELEGRAM_ALLOWED_USER_ID=6985614590

# ─── Optional ───────────────────────────────────────────
# Working directory for MiMoCode agent (default: current dir)
# MIMO_WORK_DIR=/root

# Stream edit interval in ms (default: 600)
# STREAM_EDIT_INTERVAL_MS=600

# Max message length for Telegram (default: 4000)
# MAX_MESSAGE_LEN=4000

# Session timeout in ms (default: 30 min)
# SESSION_TIMEOUT_MS=1800000
